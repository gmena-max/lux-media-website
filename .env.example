# Lux Media Website — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# .env.local is gitignored; never commit real secrets to the repo.

# ─── Google Analytics ────────────────────────────────────────────
# Public measurement ID, safe to commit, but env-driven lets us
# swap between staging and production tracking.
NEXT_PUBLIC_GA_ID=G-XKSDRLY742

# ─── GoHighLevel (GHL) — form submissions + chat widget ─────────
# Get real values from app.gohighlevel.com → Automations → Webhooks
# (and your Location ID + public booking calendar URL).
# These are PUBLIC in the compiled JS (prefixed NEXT_PUBLIC_), so treat
# them as endpoints, not secrets — but still put them in env to keep
# the source clean and environment-specific.
NEXT_PUBLIC_GHL_CONTACT_WEBHOOK_URL=
NEXT_PUBLIC_GHL_AUDIT_WEBHOOK_URL=
NEXT_PUBLIC_GHL_LOCATION_ID=
NEXT_PUBLIC_GHL_CALENDAR_URL=

# ─── EmailJS (legacy, in use on main while GHL migration is WIP) ──
# Free tier account at emailjs.com. These IDs are exposed in
# compiled JS so they're effectively public, but env-driven is still
# better practice.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_fne0p1e
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_ekh8oaa
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=obYLKk_Gy-8jb8fdt

# ─── WhatsApp ────────────────────────────────────────────────────
# Business phone without + or dashes (for wa.me links).
# Also displayed formatted across the site.
NEXT_PUBLIC_WHATSAPP_PHONE=50671911587
NEXT_PUBLIC_WHATSAPP_PHONE_DISPLAY=+506 7191-1587

# ─── Contact ─────────────────────────────────────────────────────
NEXT_PUBLIC_CONTACT_EMAIL=gabriel@luxmediacr.com
